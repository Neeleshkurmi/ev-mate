{
  "info": {
    "name": "EV-Mate API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Time-based EV charging booking, availability, and stations."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "stationId",
      "value": ""
    },
    {
      "key": "bookingId",
      "value": ""
    },
    {
      "key": "providerApiKey",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Stations",
      "item": [
        {
          "name": "List stations",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/stations?page=1&limit=10&availability=true"
          }
        },
        {
          "name": "Nearby stations",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/stations/nearby?lat=23.2334&lng=77.4347&radiusKm=25"
          }
        },
        {
          "name": "Station availability (UTC day)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/stations/{{stationId}}/availability?date=2026-05-12"
          }
        },
        {
          "name": "Station free slots",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/stations/{{stationId}}/free-slots?date=2026-05-12&durationMinutes=60&stepMinutes=15"
          }
        },
        {
          "name": "Station state",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/stations/{{stationId}}/state"
          }
        },
        {
          "name": "Aggregated station states",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/stations/aggregated"
          }
        },
        {
          "name": "Live metrics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/stations/{{stationId}}/live-metrics"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/bookings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stationId\": \"{{stationId}}\",\n  \"startTime\": \"2026-05-12T14:00:00.000Z\",\n  \"endTime\": \"2026-05-12T15:00:00.000Z\"\n}"
            }
          }
        },
        {
          "name": "My bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/bookings/user"
          }
        },
        {
          "name": "Cancel booking",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}"
          }
        }
      ]
    },
    {
      "name": "Providers",
      "item": [
        {
          "name": "Ingest telemetry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-provider-api-key",
                "value": "{{providerApiKey}}"
              }
            ],
            "url": "{{baseUrl}}/api/providers/telemetry",
            "body": {
              "mode": "raw",
              "raw": "{\"stationId\":\"{{stationId}}\",\"chargerStatus\":\"BUSY\",\"activeSessions\":2,\"powerUsage\":24.5,\"temperature\":31,\"providerTimestamp\":\"2026-05-12T14:00:00.000Z\"}"
            }
          }
        },
        {
          "name": "Provider webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-provider-api-key",
                "value": "{{providerApiKey}}"
              }
            ],
            "url": "{{baseUrl}}/api/providers/webhook",
            "body": {
              "mode": "raw",
              "raw": "{\"telemetry\":{\"stationId\":\"{{stationId}}\",\"status\":\"BUSY\",\"active_sessions\":2,\"power_usage\":24.5,\"temperature\":31,\"timestamp\":\"2026-05-12T14:00:00.000Z\"}}"
            }
          }
        }
      ]
    }
  ]
}