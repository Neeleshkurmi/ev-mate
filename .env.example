PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:root@localhost:5432/ev_booking?schema=public
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=7d
GOOGLE_MAPS_API_KEY=replace_with_google_maps_api_key
CLIENT_URL=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
PROVIDER_STALE_MS=180000
AGGREGATION_HORIZON_MINUTES=360
AGGREGATION_WINDOW_DURATION_MINUTES=60
AGGREGATION_WINDOW_STEP_MINUTES=15
STATION_STATE_CACHE_TTL_MS=5000
PROVIDER_STALE_CHECK_INTERVAL_MS=60000
